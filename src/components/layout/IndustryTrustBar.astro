---
// Industry Trust Bar - Logo slider with grayscale hover effect
// Displays industry certifications and review platforms

const logos = [
    {
        name: "NATE",
        description: "HVAC Certification",
        initials: "NATE",
    },
    {
        name: "PHCC",
        description: "Plumbing Certification",
        initials: "PHCC",
    },
    {
        name: "Google Reviews",
        description: "Google Reviews",
        initials: "G",
    },
    {
        name: "Yelp",
        description: "Yelp Reviews",
        initials: "Y",
    },
];
---

<section
    class="py-12 md:py-16 px-6 bg-parchment border-t border-b border-[#E5E7EB]"
>
    <div class="container-custom">
        <!-- Section Title -->
        <div class="text-center mb-12">
            <span
                class="text-sm font-semibold tracking-widest uppercase text-steel-pewter"
                style="color: var(--helios-orange);"
            >
                TRUSTED BY INDUSTRY LEADERS
            </span>
            <h2 class="heading-primary mt-4 mb-4">Certified & Recognized</h2>
        </div>

        <!-- Desktop: Infinite Scroll Animation -->
        <div class="hidden md:block overflow-hidden">
            <div class="flex animate-scroll gap-12 w-max">
                {
                    logos.map((logo) => (
                        <div class="flex-shrink-0">
                            <div class="w-32 h-32 rounded-xl flex items-center justify-center transition-all duration-300 group hover:shadow-lg bg-white border border-[#E5E7EB]">
                                <div
                                    class="text-center group-hover:opacity-100 transition-all duration-300"
                                    style="filter: grayscale(100%); opacity: 0.7;"
                                >
                                    <div class="text-3xl font-bold text-[#0A1931] mb-2">
                                        {logo.initials}
                                    </div>
                                    <p class="text-xs font-semibold text-machinist">
                                        {logo.name}
                                    </p>
                                </div>
                            </div>
                        </div>
                    ))
                }
                {/* Duplicate for seamless loop */}
                {
                    logos.map((logo) => (
                        <div class="flex-shrink-0">
                            <div class="w-32 h-32 rounded-xl flex items-center justify-center transition-all duration-300 group hover:shadow-lg bg-white border border-[#E5E7EB]">
                                <div
                                    class="text-center group-hover:opacity-100 transition-all duration-300"
                                    style="filter: grayscale(100%); opacity: 0.7;"
                                >
                                    <div class="text-3xl font-bold text-[#0A1931] mb-2">
                                        {logo.initials}
                                    </div>
                                    <p class="text-xs font-semibold text-machinist">
                                        {logo.name}
                                    </p>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Mobile: Grid Layout -->
        <div class="md:hidden grid grid-cols-2 gap-6">
            {
                logos.map((logo) => (
                    <div class="w-full h-28 rounded-xl flex items-center justify-center transition-all duration-300 group hover:shadow-lg bg-white border border-[#E5E7EB]">
                        <div
                            class="text-center group-hover:opacity-100 transition-all duration-300"
                            style="filter: grayscale(100%); opacity: 0.7;"
                        >
                            <div class="text-2xl font-bold text-[#0A1931] mb-1">
                                {logo.initials}
                            </div>
                            <p class="text-xs font-semibold text-machinist">
                                {logo.name}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    @keyframes scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    .animate-scroll {
        animation: scroll 30s linear infinite;
    }

    .animate-scroll:hover {
        animation-play-state: paused;
    }
</style>
