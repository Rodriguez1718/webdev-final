      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Real Results for <span style="color: var(--helios-orange);">Real Contractors</span>
      </h2>
      <p class="text-lg max-w-3xl mx-auto leading-relaxed" style="color: var(--steel-pewter);">
        See how we've transformed contractor businesses with custom websites that generate leads, build trust, and drive growth.
      </p>
    </div>

    <!-- Case Studies Carousel -->
    <div class="relative">
      <!-- Left Navigation Arrow -->
      <button class="carousel-prev absolute left-0 top-1/2 transform -translate-y-1/2 z-10 bg-white/10 hover:bg-white/20 text-white p-4 rounded-full transition-all duration-300 hover:scale-110 backdrop-filter backdrop-blur-sm border border-white/20 group" style="margin-left: -3rem;">
        <svg class="w-6 h-6 transition-transform duration-300 group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      <!-- Right Navigation Arrow -->
      <button class="carousel-next absolute right-0 top-1/2 transform -translate-y-1/2 z-10 bg-white/10 hover:bg-white/20 text-white p-4 rounded-full transition-all duration-300 hover:scale-110 backdrop-filter backdrop-blur-sm border border-white/20 group" style="margin-right: -3rem;">
