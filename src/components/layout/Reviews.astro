---
// Enhanced Reviews Section with Landscape Layout
---

<section class="py-20 relative overflow-hidden" style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 90%, var(--steel-pewter) 10%) 100%);">
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-block px-6 py-3 rounded-full text-sm font-semibold tracking-wider uppercase mb-6" style="background: color-mix(in srgb, var(--helios-orange) 15%, transparent); color: var(--helios-orange);">
        Success Stories
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Real Results for <span style="color: var(--helios-orange);">Real Contractors</span>
      </h2>
      <p class="text-lg max-w-3xl mx-auto leading-relaxed" style="color: var(--steel-pewter);">
        See how we've transformed contractor businesses with custom websites that generate leads, build trust, and drive growth.
      </p>
    </div>

    <!-- Landscape Layout: Website Left, Reviews Right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left Side: Website Mockups with Fade Transition -->
      <div class="relative">
        <!-- Website Display Container -->
        <div class="website-display-container relative">
          <!-- HVAC Website -->
          <div class="website-mockup active" data-website="0">
            <div class="device-mockup-large">
              <div class="device-screen-large">
                <div class="mockup-header-large">
                  <div class="mockup-nav-large">
                    <div class="nav-dots-large">
                      <span></span><span></span><span></span>
                    </div>
                    <div class="nav-url-large">coolairpro.com</div>
                  </div>
                </div>
                <div class="mockup-content-large hvac-theme">
                  <div class="hero-section-large">
                    <h3>HVAC Solutions</h3>
                    <p>Professional Heating & Cooling Services</p>
                    <div class="cta-button-large">Get Free Quote Today</div>
                  </div>
                  <div class="features-grid-large">
                    <div class="feature-item-large">24/7 Emergency Service</div>
                    <div class="feature-item-large">Licensed Professionals</div>
                    <div class="feature-item-large">Free Estimates</div>
                    <div class="feature-item-large">Warranty Included</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Plumbing Website -->
          <div class="website-mockup" data-website="1">
            <div class="device-mockup-large">
              <div class="device-screen-large">
                <div class="mockup-header-large">
                  <div class="mockup-nav-large">
                    <div class="nav-dots-large">
                      <span></span><span></span><span></span>
                    </div>
                    <div class="nav-url-large">rapidplumbingpro.com</div>
                  </div>
                </div>
                <div class="mockup-content-large plumbing-theme">
                  <div class="hero-section-large">
                    <h3>Rapid Plumbing Pro</h3>
                    <p>Emergency & Residential Plumbing Services</p>
                    <div class="cta-button-large">Call Now: (555) 123-4567</div>
                  </div>
                  <div class="features-grid-large">
                    <div class="feature-item-large">24/7 Emergency Response</div>
                    <div class="feature-item-large">Licensed & Insured</div>
                    <div class="feature-item-large">Same Day Service</div>
                    <div class="feature-item-large">Upfront Pricing</div>
                  </div>
                </div>
              </div>
            </div>
          </div>


        </div>
      </div>

      <!-- Right Side: Reviews Carousel with Swipe Transition -->
      <div class="relative">
        <!-- Navigation Arrows -->
        <button class="carousel-prev absolute left-0 top-1/2 transform -translate-y-1/2 z-10 text-white p-4 transition-all duration-300 hover:scale-110 hover:opacity-70" style="margin-left: -3rem;">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>

        <button class="carousel-next absolute right-0 top-1/2 transform -translate-y-1/2 z-10 text-white p-4 transition-all duration-300 hover:scale-110 hover:opacity-70" style="margin-right: -3rem;">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>

        <!-- Reviews Container -->
        <div class="reviews-container overflow-hidden">
          <div class="reviews-track flex transition-transform duration-500 ease-in-out">
            <!-- Review 1 - HVAC -->
            <div class="review-slide flex-shrink-0 w-full">
              <div class="review-card">
                <div class="review-header">
                  <h3 class="review-title">HVAC Company Transformation</h3>
                  <div class="rating">
                    <div class="stars">★★★★★</div>
                    <span class="rating-text">5.0 Client Rating</span>
                  </div>
                </div>
                
                <p class="review-description">
                  CoolAir Pro saw a 340% increase in qualified leads within 3 months of launching their new website. 
                  Our conversion-focused design and local SEO strategy transformed their online presence.
                </p>
                
                <div class="review-metrics">
                  <div class="metric">
                    <div class="metric-value">340%</div>
                    <div class="metric-label">Lead Increase</div>
                  </div>
                  <div class="metric">
                    <div class="metric-value">$85K</div>
                    <div class="metric-label">Monthly Revenue</div>
                  </div>
                  <div class="metric">
                    <div class="metric-value">2.3x</div>
                    <div class="metric-label">Conversion Rate</div>
                  </div>
                </div>
                
                <div class="client-testimonial">
                  <div class="testimonial-text">
                    "BuildPro completely transformed our online presence. The leads keep coming!"
                  </div>
                  <div class="client-info">
                    <div class="client-avatar">JM</div>
                    <div class="client-details">
                      <div class="client-name">Jake Martinez</div>
                      <div class="client-company">CoolAir Pro, Phoenix</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <!-- Review 2 - Plumbing -->
            <div class="review-slide flex-shrink-0 w-full">
              <div class="review-card">
                <div class="review-header">
                  <h3 class="review-title">Plumbing Service Growth</h3>
                  <div class="rating">
                    <div class="stars">★★★★★</div>
                    <span class="rating-text">5.0 Client Rating</span>
                  </div>
                </div>
                
                <p class="review-description">
                  Rapid Plumbing Pro doubled their emergency call volume and expanded to 3 new service areas 
                  after launching their mobile-optimized website with integrated booking system.
                </p>
                
                <div class="client-testimonial">
                  <div class="testimonial-text">
                    "Our phone hasn't stopped ringing since the new site went live. Amazing work!"
                  </div>
                  <div class="client-info">
                    <div class="client-avatar">SR</div>
                    <div class="client-details">
                      <div class="client-name">Sarah Rodriguez</div>
                      <div class="client-company">Rapid Plumbing, Denver</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Review 3 - HVAC -->
            <div class="review-slide flex-shrink-0 w-full">
              <div class="review-card">
                <div class="review-header">
                  <h3 class="review-title">HVAC Expansion Success</h3>
                  <div class="rating">
                    <div class="stars">★★★★★</div>
                    <span class="rating-text">5.0 Client Rating</span>
                  </div>
                </div>
                
                <p class="review-description">
                  ComfortZone HVAC tripled their service requests and expanded their team by 40% after their new website launched with advanced scheduling and customer portal features.
                </p>
                
                <div class="client-testimonial">
                  <div class="testimonial-text">
                    "BuildPro's website has been a game-changer for our business. We're booking jobs weeks in advance!"
                  </div>
                  <div class="client-info">
                    <div class="client-avatar">DK</div>
                    <div class="client-details">
                      <div class="client-name">David Kim</div>
                      <div class="client-company">ComfortZone HVAC, Austin</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Review 4 - Plumbing -->
            <div class="review-slide flex-shrink-0 w-full">
              <div class="review-card">
                <div class="review-header">
                  <h3 class="review-title">Emergency Plumbing Growth</h3>
                  <div class="rating">
                    <div class="stars">★★★★★</div>
                    <span class="rating-text">5.0 Client Rating</span>
                  </div>
                </div>
                
                <p class="review-description">
                  ProFlow Plumbing increased their emergency call response rate by 180% with a website that highlights their 24/7 availability and rapid response times across multiple service areas.
                </p>
                
                <div class="client-testimonial">
                  <div class="testimonial-text">
                    "The website BuildPro created perfectly showcases our emergency services. Customers trust us immediately!"
                  </div>
                  <div class="client-info">
                    <div class="client-avatar">MC</div>
                    <div class="client-details">
                      <div class="client-name">Marcus Chen</div>
                      <div class="client-company">ProFlow Plumbing, Portland</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Carousel Indicators -->
        <div class="flex justify-center mt-8 gap-3">
          <button class="carousel-dot w-3 h-3 rounded-full bg-white/30 hover:bg-white/50 transition-all duration-300 active hover:scale-125" data-slide="0"></button>
          <button class="carousel-dot w-3 h-3 rounded-full bg-white/30 hover:bg-white/50 transition-all duration-300 hover:scale-125" data-slide="1"></button>
          <button class="carousel-dot w-3 h-3 rounded-full bg-white/30 hover:bg-white/50 transition-all duration-300 hover:scale-125" data-slide="2"></button>
          <button class="carousel-dot w-3 h-3 rounded-full bg-white/30 hover:bg-white/50 transition-all duration-300 hover:scale-125" data-slide="3"></button>
        </div>
      </div>
    </div>
  </div>
</section>
<style>
  /* Website Mockup Styles - Large Version */
  .website-display-container {
    position: relative;
    height: 500px;
  }

  .website-mockup {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
    pointer-events: none;
  }

  .website-mockup.active {
    opacity: 1;
    pointer-events: auto;
  }

  .device-mockup-large {
    background: #1a1a1a;
    border-radius: 1.5rem;
    padding: 1.5rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
    transform: perspective(1000px) rotateY(-5deg) rotateX(5deg);
  }

  .device-screen-large {
    background: white;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.1);
  }

  .mockup-header-large {
    background: #f5f5f5;
    padding: 1rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .mockup-nav-large {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-dots-large {
    display: flex;
    gap: 0.5rem;
  }

  .nav-dots-large span {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: #ddd;
  }

  .nav-dots-large span:first-child { background: #ff5f57; }
  .nav-dots-large span:nth-child(2) { background: #ffbd2e; }
  .nav-dots-large span:nth-child(3) { background: #28ca42; }

  .nav-url-large {
    background: white;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    color: #666;
    border: 1px solid #e0e0e0;
  }

  .mockup-content-large {
    padding: 2rem;
    min-height: 300px;
  }

  .hvac-theme {
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
    color: white;
  }

  .plumbing-theme {
    background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 80%, var(--steel-pewter) 20%) 100%);
    color: white;
  }

  .electrician-theme {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: white;
  }

  .construction-theme {
    background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    color: white;
  }

  .roofing-theme {
    background: linear-gradient(135deg, #059669 0%, #047857 100%);
    color: white;
  }

  .landscaping-theme {
    background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    color: white;
  }

  .hero-section-large h3 {
    font-size: 1.75rem;
    font-weight: bold;
    margin-bottom: 0.75rem;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .hero-section-large p {
    opacity: 0.9;
    margin-bottom: 1.5rem;
    font-weight: 500;
    font-size: 1.1rem;
  }

  .cta-button-large {
    background: var(--helios-orange);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    font-weight: bold;
    font-size: 1rem;
    display: inline-block;
    margin-bottom: 1.5rem;
    box-shadow: 0 6px 16px rgba(244, 140, 6, 0.4);
    transition: all 0.3s ease;
  }

  .cta-button-large:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(244, 140, 6, 0.5);
  }

  .features-grid-large {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .feature-item-large {
    background: rgba(255, 255, 255, 0.2);
    padding: 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    text-align: center;
    font-weight: 600;
    backdrop-filter: blur(5px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Review Card Styles */
  .review-card {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 1.5rem;
    padding: 2rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    height: 500px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .review-title {
    font-size: 1.5rem;
    font-weight: bold;
    background: linear-gradient(135deg, white 0%, var(--steel-pewter) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .rating {
    text-align: right;
  }

  .stars {
    color: var(--helios-orange);
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .rating-text {
    font-size: 0.875rem;
    color: var(--steel-pewter);
  }

  .review-description {
    color: var(--steel-pewter);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .review-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .metric {
    text-align: center;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 0.75rem;
  }

  .metric-value {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--helios-orange);
    margin-bottom: 0.25rem;
  }

  .metric-label {
    font-size: 0.875rem;
    color: var(--steel-pewter);
  }

  .client-testimonial {
    background: rgba(255, 255, 255, 0.05);
    padding: 1.5rem;
    border-radius: 1rem;
    border-left: 4px solid var(--helios-orange);
  }

  .testimonial-text {
    font-style: italic;
    margin-bottom: 1rem;
    line-height: 1.5;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.95);
    position: relative;
  }

  .testimonial-text::before {
    content: '"';
    font-size: 2.5rem;
    color: var(--helios-orange);
    position: absolute;
    left: -1rem;
    top: -0.5rem;
    font-family: serif;
  }

  .testimonial-text::after {
    content: '"';
    font-size: 2.5rem;
    color: var(--helios-orange);
    position: absolute;
    right: -0.5rem;
    bottom: -1.5rem;
    font-family: serif;
  }

  .client-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .client-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--helios-orange);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: white;
  }

  .client-name {
    font-weight: bold;
    margin-bottom: 0.25rem;
    color: white;
    font-size: 1rem;
  }

  .client-company {
    font-size: 0.875rem;
    color: var(--helios-orange);
    font-weight: 500;
  }

  /* Carousel Styles */
  .reviews-container {
    position: relative;
    overflow: hidden;
  }

  .reviews-track {
    will-change: transform;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .review-slide {
    min-width: 100%;
    flex-shrink: 0;
  }

  .carousel-dot.active {
    background: var(--helios-orange) !important;
    transform: scale(1.3);
    box-shadow: 0 0 12px rgba(244, 140, 6, 0.5);
  }

  .carousel-prev:hover,
  .carousel-next:hover {
    opacity: 0.7;
  }

  @media (max-width: 1024px) {
    .device-mockup-large {
      transform: none;
    }
    
    .review-metrics {
      grid-template-columns: 1fr;
    }
    
    .features-grid-large {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .review-header {
      flex-direction: column;
      gap: 1rem;
    }
    
    .rating {
      text-align: left;
    }
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const reviewsTrack = document.querySelector('.reviews-track');
    const reviewSlides = document.querySelectorAll('.review-slide');
    const websiteMockups = document.querySelectorAll('.website-mockup');
    const dots = document.querySelectorAll('.carousel-dot');
    const prevBtn = document.querySelector('.carousel-prev');
    const nextBtn = document.querySelector('.carousel-next');
    
    let currentSlide = 0;
    const totalSlides = reviewSlides.length;
    let autoSlideInterval;
    
    function updateCarousel() {
      // Update reviews carousel (swipe transition)
      const translateX = -currentSlide * 100;
      reviewsTrack.style.transform = `translateX(${translateX}%)`;
      
      // Update website mockups (fade transition)
      websiteMockups.forEach((mockup, index) => {
        mockup.classList.toggle('active', index === currentSlide);
      });
      
      // Update dots
      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentSlide);
      });
    }
    
    function nextSlide() {
      currentSlide = (currentSlide + 1) % totalSlides;
      updateCarousel();
    }
    
    function prevSlide() {
      currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
      updateCarousel();
    }
    
    function goToSlide(slideIndex) {
      currentSlide = slideIndex;
      updateCarousel();
    }
    
    function startAutoSlide() {
      autoSlideInterval = setInterval(nextSlide, 6000); // Auto-advance every 6 seconds
    }
    
    function stopAutoSlide() {
      clearInterval(autoSlideInterval);
    }
    
    // Event listeners
    nextBtn.addEventListener('click', () => {
      nextSlide();
      stopAutoSlide();
      startAutoSlide(); // Restart auto-slide after manual interaction
    });
    
    prevBtn.addEventListener('click', () => {
      prevSlide();
      stopAutoSlide();
      startAutoSlide(); // Restart auto-slide after manual interaction
    });
    
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        goToSlide(index);
        stopAutoSlide();
        startAutoSlide(); // Restart auto-slide after manual interaction
      });
    });
    
    // Pause auto-slide on hover
    const reviewsContainer = document.querySelector('.reviews-container');
    const websiteContainer = document.querySelector('.website-display-container');
    
    [reviewsContainer, websiteContainer].forEach(container => {
      container.addEventListener('mouseenter', stopAutoSlide);
      container.addEventListener('mouseleave', startAutoSlide);
    });
    
    // Initialize
    updateCarousel();
    startAutoSlide();
  });
</script>