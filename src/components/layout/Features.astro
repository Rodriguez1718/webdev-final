---
// Enhanced Features Section with Case Studies and Services
---

<section class="py-20 relative overflow-hidden" style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 90%, var(--steel-pewter) 10%) 100%);">
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-block px-6 py-3 rounded-full text-sm font-semibold tracking-wider uppercase mb-6" style="background: color-mix(in srgb, var(--helios-orange) 15%, transparent); color: var(--helios-orange);">
        Success Stories
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Real Results for <span style="color: var(--helios-orange);">Real Contractors</span>
      </h2>
      <p class="text-lg max-w-3xl mx-auto leading-relaxed" style="color: var(--steel-pewter);">
        See how we've transformed contractor businesses with custom websites that generate leads, build trust, and drive growth.
      </p>
    </div>

    <!-- Case Studies Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20">
      <!-- HVAC Case Study -->
      <div class="case-study-card group">
        <div class="case-study-content">
          <!-- Mock Device Display -->
          <div class="device-mockup">
            <div class="device-screen">
              <div class="mockup-header">
                <div class="mockup-nav">
                  <div class="nav-dots">
                    <span></span><span></span><span></span>
                  </div>
                  <div class="nav-url">coolairpro.com</div>
                </div>
              </div>
              <div class="mockup-content hvac-theme">
                <div class="hero-section">
                  <h3>HVAC Solutions</h3>
                  <p>Professional Heating & Cooling</p>
                  <div class="cta-button">Get Free Quote</div>
                </div>
                <div class="features-grid">
                  <div class="feature-item">24/7 Service</div>
                  <div class="feature-item">Licensed Pros</div>
                  <div class="feature-item">Free Estimates</div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Case Study Info -->
          <div class="case-info">
            <div class="case-header">
              <h3 class="case-title">HVAC Company Transformation</h3>
              <div class="rating">
                <div class="stars">★★★★★</div>
                <span class="rating-text">5.0 Client Rating</span>
              </div>
            </div>
            
            <p class="case-description">
              CoolAir Pro saw a 340% increase in qualified leads within 3 months of launching their new website. 
              Our conversion-focused design and local SEO strategy transformed their online presence.
            </p>
            
            <div class="case-metrics">
              <div class="metric">
                <div class="metric-value">340%</div>
                <div class="metric-label">Lead Increase</div>
              </div>
              <div class="metric">
                <div class="metric-value">$85K</div>
                <div class="metric-label">Monthly Revenue</div>
              </div>
              <div class="metric">
                <div class="metric-value">2.3x</div>
                <div class="metric-label">Conversion Rate</div>
              </div>
            </div>
            
            <div class="client-testimonial">
              <div class="testimonial-text">
                "BuildPro completely transformed our online presence. The leads keep coming!"
              </div>
              <div class="client-info">
                <div class="client-avatar">JM</div>
                <div class="client-details">
                  <div class="client-name">Jake Martinez</div>
                  <div class="client-company">CoolAir Pro, Phoenix</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Plumbing Case Study -->
      <div class="case-study-card group">
        <div class="case-study-content">
          <!-- Mock Device Display -->
          <div class="device-mockup">
            <div class="device-screen">
              <div class="mockup-header">
                <div class="mockup-nav">
                  <div class="nav-dots">
                    <span></span><span></span><span></span>
                  </div>
                  <div class="nav-url">rapidplumbingpro.com</div>
                </div>
              </div>
              <div class="mockup-content plumbing-theme">
                <div class="hero-section">
                  <h3>Rapid Plumbing</h3>
                  <p>Emergency & Residential Services</p>
                  <div class="cta-button">Call Now: (555) 123-4567</div>
                </div>
                <div class="features-grid">
                  <div class="feature-item">Emergency 24/7</div>
                  <div class="feature-item">Licensed & Insured</div>
                  <div class="feature-item">Same Day Service</div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Case Study Info -->
          <div class="case-info">
            <div class="case-header">
              <h3 class="case-title">Plumbing Service Growth</h3>
              <div class="rating">
                <div class="stars">★★★★★</div>
                <span class="rating-text">5.0 Client Rating</span>
              </div>
            </div>
            
            <p class="case-description">
              Rapid Plumbing Pro doubled their emergency call volume and expanded to 3 new service areas 
              after launching their mobile-optimized website with integrated booking system.
            </p>
            
            <div class="case-metrics">
              <div class="metric">
                <div class="metric-value">200%</div>
                <div class="metric-label">Call Volume</div>
              </div>
              <div class="metric">
                <div class="metric-value">$120K</div>
                <div class="metric-label">Monthly Revenue</div>
              </div>
              <div class="metric">
                <div class="metric-value">3</div>
                <div class="metric-label">New Markets</div>
              </div>
            </div>
            
            <div class="client-testimonial">
              <div class="testimonial-text">
                "Our phone hasn't stopped ringing since the new site went live. Amazing work!"
              </div>
              <div class="client-info">
                <div class="client-avatar">SR</div>
                <div class="client-details">
                  <div class="client-name">Sarah Rodriguez</div>
                  <div class="client-company">Rapid Plumbing, Denver</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .case-study-card {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 1.5rem;
    padding: 2rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  .case-study-card:hover {
    transform: translateY(-8px);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
  }

  .case-study-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .device-mockup {
    background: #1a1a1a;
    border-radius: 1rem;
    padding: 1rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }

  .device-screen {
    background: white;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .mockup-header {
    background: #f5f5f5;
    padding: 0.75rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .mockup-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-dots {
    display: flex;
    gap: 0.25rem;
  }

  .nav-dots span {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: #ddd;
  }

  .nav-dots span:first-child { background: #ff5f57; }
  .nav-dots span:nth-child(2) { background: #ffbd2e; }
  .nav-dots span:nth-child(3) { background: #28ca42; }

  .nav-url {
    background: white;
    padding: 0.25rem 0.75rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    color: #666;
  }

  .mockup-content {
    padding: 1.5rem;
    min-height: 200px;
  }

  .hvac-theme {
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
    color: white;
  }

  .plumbing-theme {
    background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 80%, var(--steel-pewter) 20%) 100%);
    color: white;
  }

  .hero-section h3 {
    font-size: 1.25rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .hero-section p {
    opacity: 0.9;
    margin-bottom: 1rem;
  }

  .cta-button {
    background: var(--helios-orange);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-weight: bold;
    font-size: 0.875rem;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .feature-item {
    background: rgba(255, 255, 255, 0.2);
    padding: 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    text-align: center;
  }

  .case-info {
    color: white;
  }

  .case-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .case-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .rating {
    text-align: right;
  }

  .stars {
    color: var(--helios-orange);
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .rating-text {
    font-size: 0.875rem;
    color: var(--steel-pewter);
  }

  .case-description {
    color: var(--steel-pewter);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .case-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .metric {
    text-align: center;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 0.75rem;
  }

  .metric-value {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--helios-orange);
    margin-bottom: 0.25rem;
  }

  .metric-label {
    font-size: 0.875rem;
    color: var(--steel-pewter);
  }

  .client-testimonial {
    background: rgba(255, 255, 255, 0.05);
    padding: 1.5rem;
    border-radius: 1rem;
    border-left: 4px solid var(--helios-orange);
  }

  .testimonial-text {
    font-style: italic;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .client-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .client-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--helios-orange);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: white;
  }

  .client-name {
    font-weight: bold;
    margin-bottom: 0.25rem;
  }

  .client-company {
    font-size: 0.875rem;
    color: var(--steel-pewter);
  }

  @media (max-width: 1024px) {
    .case-study-content {
      gap: 1.5rem;
    }
    
    .case-header {
      flex-direction: column;
      gap: 1rem;
    }
    
    .rating {
      text-align: left;
    }
  }

  @media (max-width: 768px) {
    .case-metrics {
      grid-template-columns: 1fr;
    }
    
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>