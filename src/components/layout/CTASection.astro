---
// CTA Section Component - Call to Action with feature cards
// Matches the dark navy/orange theme of the website
import Button from "../ui/Button.astro";
---

<section
    class="py-16 md:py-24 px-4 md:px-6 lg:px-8"
    style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 90%, var(--steel-pewter) 10%) 100%);"
>
    <div class="w-full">
        <!-- Main Container -->
        <div
            class="rounded-2xl p-8 md:p-12 border"
            style="background: rgba(255, 255, 255, 0.05); border-color: rgba(244, 140, 6, 0.2); backdrop-filter: blur(10px);"
        >
            <!-- Header Section -->
            <div
                class="flex flex-col md:flex-row md:items-center md:justify-between mb-12 gap-6"
            >
                <div class="flex-1">
                    <h2 class="heading-primary mb-4">
                        Ready to Transform Your Business?
                    </h2>
                    <p class="text-body text-lg max-w-2xl">
                        Join thousands of contractors and trades professionals
                        who've already elevated their digital presence. Let's
                        build something great together.
                    </p>
                </div>

                <!-- CTA Button -->
                <div class="shrink-0">
                    <Button variant="primary" size="md" href="/contact">
                        Get Started Today
                    </Button>
                </div>
            </div>

            <!-- Features Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Feature Card 1 - Highlighted -->
                <div
                    class="rounded-xl p-6 text-white transition-all duration-300 hover:shadow-lg hover:scale-105"
                    style="background: linear-gradient(135deg, var(--button-color) 0%, #144069 100%);"
                >
                    <div
                        class="flex items-center justify-center w-12 h-12 rounded-lg bg-white/20 mb-4"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">Fast Setup</h3>
                    <p class="text-sm text-white/90">
                        Get your online presence up and running in minutes, not
                        weeks.
                    </p>
                    <div class="mt-4">
                        <Button
                            variant="ghost"
                            size="sm"
                            href="#"
                            class="!bg-transparent !border-2 !border-white !text-white hover:!text-[#F48C06] hover:!border-[#F48C06]"
                        >
                            Learn More
                        </Button>
                    </div>
                </div>

                <!-- Feature Card 2 -->
                <div
                    class="rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:scale-105"
                    style="background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(244, 140, 6, 0.2);"
                >
                    <div
                        class="flex items-center justify-center w-12 h-12 rounded-lg mb-4"
                        style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%); color: white;"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2 text-white">
                        Proven Results
                    </h3>
                    <p class="text-sm text-white/80">
                        See measurable growth in leads and customer inquiries
                        within weeks.
                    </p>
                    <div class="mt-4">
                        <Button
                            variant="ghost"
                            size="sm"
                            href="#"
                            class="!bg-transparent !border-2 !border-white !text-white hover:!text-[#F48C06] hover:!border-[#F48C06]"
                        >
                            Learn More
                        </Button>
                    </div>
                </div>

                <!-- Feature Card 3 -->
                <div
                    class="rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:scale-105"
                    style="background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(244, 140, 6, 0.2);"
                >
                    <div
                        class="flex items-center justify-center w-12 h-12 rounded-lg mb-4"
                        style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%); color: white;"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2 text-white">
                        Expert Support
                    </h3>
                    <p class="text-sm text-white/80">
                        Our team is here to help you succeed every step of the
                        way.
                    </p>
                    <div class="mt-4">
                        <Button
                            variant="ghost"
                            size="sm"
                            href="#"
                            class="!bg-transparent !border-2 !border-white !text-white hover:!text-[#F48C06] hover:!border-[#F48C06]"
                        >
                            Learn More
                        </Button>
                    </div>
                </div>

                <!-- Feature Card 4 -->
                <div
                    class="rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:scale-105"
                    style="background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(244, 140, 6, 0.2);"
                >
                    <div
                        class="flex items-center justify-center w-12 h-12 rounded-lg mb-4"
                        style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%); color: white;"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2 text-white">
                        24/7 Available
                    </h3>
                    <p class="text-sm text-white/80">
                        Your business works around the clock, so should your
                        online presence.
                    </p>
                    <div class="mt-4">
                        <Button
                            variant="ghost"
                            size="sm"
                            href="#"
                            class="!bg-transparent !border-2 !border-white !text-white hover:!text-[#F48C06] hover:!border-[#F48C06]"
                        >
                            Learn More
                        </Button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .heading-primary {
        font-size: 2.25rem;
        font-weight: 700;
        color: white;
        line-height: 1.2;
    }

    .text-body {
        color: var(--steel-pewter);
        line-height: 1.6;
    }

    @media (max-width: 768px) {
        .heading-primary {
            font-size: 1.875rem;
        }
    }
</style>
