---
// CTA Section Component - Simple call-to-action banner
// Placed above footer on all pages
import Button from "../ui/Button.astro";

export interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
  phoneNumber?: string;
}

const {
  title = "Ready to Transform Your Business?",
  description = "Get started today and see how we can help you grow your contractor business with a powerful online presence.",
  buttonText = "Get Started",
  buttonLink = "/contact",
  phoneNumber = "(555) 123-4567",
} = Astro.props;
---

<section class="py-20 md:py-24 px-4 md:px-6 lg:px-8 bg-parchment">
  <div class="max-w-5xl mx-auto text-center">
    <!-- Main Heading -->
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#0A1931] mb-6">
      {title}
    </h2>

    <!-- Description -->
    <p class="text-lg md:text-xl text-[#7E7E7E] mb-10 max-w-3xl mx-auto">
      {description}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <!-- Primary CTA Button -->
      <Button href={buttonLink} variant="primary" size="md">
        {buttonText}
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </Button>

      <!-- Phone CTA -->
      <Button
        href={`tel:${phoneNumber.replace(/[^0-9]/g, "")}`}
        variant="ghost"
        size="md"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path
            d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
          ></path>
        </svg>
        Call {phoneNumber}
      </Button>
    </div>

    <!-- Trust Indicators -->
    <div class="mt-12 pt-8 border-t border-[#99B0BB]/30">
      <div
        class="flex flex-wrap items-center justify-center gap-8 text-sm text-[#7E7E7E]"
      >
        <div class="flex items-center gap-2">
          <svg
            class="w-5 h-5 text-[#F48C06]"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
              clip-rule="evenodd"></path>
          </svg>
          <span class="font-medium">Free Consultation</span>
        </div>
        <div class="flex items-center gap-2">
          <svg
            class="w-5 h-5 text-[#F48C06]"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
              clip-rule="evenodd"></path>
          </svg>
          <span class="font-medium">No Obligation Quote</span>
        </div>
        <div class="flex items-center gap-2">
          <svg
            class="w-5 h-5 text-[#F48C06]"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
              clip-rule="evenodd"></path>
          </svg>
          <span class="font-medium">24/7 Support</span>
        </div>
      </div>
    </div>
  </div>
</section>
