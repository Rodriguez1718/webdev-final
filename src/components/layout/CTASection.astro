---
// CTA Section Component - Call to Action with feature cards
// Matches the dark navy/orange theme of the website
import Button from "../ui/Button.astro";
---

<section
    class="py-20 md:py-32 px-4 md:px-6 lg:px-8 relative overflow-hidden bg-white"
>
    <!-- Subtle background pattern -->
    <div class="absolute inset-0 opacity-5">
        <div
            class="absolute top-0 right-0 w-96 h-96 bg-[#F48C06] rounded-full blur-3xl"
        >
        </div>
        <div
            class="absolute bottom-0 left-0 w-96 h-96 bg-[#0A1931] rounded-full blur-3xl"
        >
        </div>
    </div>

    <div class="w-full relative z-10">
        <!-- Main Container -->
        <div class="max-w-6xl mx-auto">
            <!-- Header Section -->
            <div
                class="flex flex-col md:flex-row md:items-center md:justify-between mb-16 gap-8"
            >
                <div class="flex-1">
                    <div class="inline-block mb-4">
                        <span
                            class="text-[#F48C06] text-sm font-bold uppercase tracking-widest border-l-4 border-[#F48C06] pl-4"
                        >
                            Ready to Grow?
                        </span>
                    </div>
                    <h2 class="heading-primary mb-6">
                        Transform Your Business Today
                    </h2>
                    <p class="text-body text-lg max-w-2xl">
                        Join thousands of contractors and trades professionals
                        who've already elevated their digital presence. Let's
                        build something great together.
                    </p>
                </div>

                <!-- CTA Button -->
                <div class="shrink-0">
                    <Button variant="primary" size="lg" href="/contact">
                        Get Started Today
                    </Button>
                </div>
            </div>

            <!-- Features Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Feature Card 1 -->
                <div class="card">
                    <div
                        class="flex items-center justify-center w-14 h-14 rounded-lg mb-6"
                        style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                    >
                        <svg
                            class="w-7 h-7 text-white"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-[#0A1931]">
                        Fast Setup
                    </h3>
                    <p class="text-sm text-[#7E7E7E] leading-relaxed">
                        Get your online presence up and running in minutes, not
                        weeks.
                    </p>
                </div>

                <!-- Feature Card 2 -->
                <div class="card">
                    <div
                        class="flex items-center justify-center w-14 h-14 rounded-lg mb-6"
                        style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                    >
                        <svg
                            class="w-7 h-7 text-white"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-[#0A1931]">
                        Proven Results
                    </h3>
                    <p class="text-sm text-[#7E7E7E] leading-relaxed">
                        See measurable growth in leads and customer inquiries
                        within weeks.
                    </p>
                </div>

                <!-- Feature Card 3 -->
                <div class="card">
                    <div
                        class="flex items-center justify-center w-14 h-14 rounded-lg mb-6"
                        style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                    >
                        <svg
                            class="w-7 h-7 text-white"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-[#0A1931]">
                        Expert Support
                    </h3>
                    <p class="text-sm text-[#7E7E7E] leading-relaxed">
                        Our team is here to help you succeed every step of the
                        way.
                    </p>
                </div>

                <!-- Feature Card 4 -->
                <div class="card">
                    <div
                        class="flex items-center justify-center w-14 h-14 rounded-lg mb-6"
                        style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                    >
                        <svg
                            class="w-7 h-7 text-white"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-[#0A1931]">
                        24/7 Available
                    </h3>
                    <p class="text-sm text-[#7E7E7E] leading-relaxed">
                        Your business works around the clock, so should your
                        online presence.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .heading-primary {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--midnight-navy);
        line-height: 1.2;
        letter-spacing: -0.5px;
    }

    .text-body {
        color: var(--machinist);
        line-height: 1.6;
        font-size: 1.1rem;
    }

    @media (max-width: 768px) {
        .heading-primary {
            font-size: 2rem;
        }

        .text-body {
            font-size: 1rem;
        }
    }
</style>
