---
import Card from "../ui/Card.astro";
---

<section class="py-20 relative overflow-hidden bg-white">
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-block px-6 py-3 rounded-full text-sm font-semibold tracking-wider uppercase mb-6" style="background: color-mix(in srgb, var(--helios-orange) 15%, transparent); color: var(--helios-orange);">
        Our Expertise
      </div>
      <h2 class="text-4xl md:text-5xl font-bold mb-6" style="color: var(--midnight-navy);">
        Trades We <span style="color: var(--helios-orange);">Serve</span>
      </h2>
      <p class="text-lg max-w-3xl mx-auto leading-relaxed" style="color: var(--steel-pewter);">
        We specialize in creating powerful digital solutions for HVAC and plumbing contractors. Our deep industry knowledge helps us build websites that convert visitors into customers.
      </p>
    </div>

    <!-- Enhanced Trades Grid using Card Component -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
      
      <!-- HVAC Card -->
      <Card
        title="HVAC Services"
        accent="orange"
        img="https://images.unsplash.com/photo-1621905252507-b35492cc74b4?q=80&w=2069&auto=format&fit=crop"
        imgAlt="HVAC technician working on air conditioning unit"
        tags={["🔥 Heating Systems", "❄️ Air Conditioning", "💨 Ventilation", "🔧 Maintenance"]}
        trade="HVAC"
        category="Climate Control"
        description="Heating, ventilation, and air conditioning contractors who keep homes and businesses comfortable year-round. We understand the seasonal nature of your business and create websites that generate leads in all seasons."
      >
        <div class="space-y-4">
          <!-- Stats Section -->
          <div class="grid grid-cols-3 gap-4 py-4 border-t border-b border-gray-200">
            <div class="text-center">
              <div class="text-2xl font-bold text-[#F48C06]">24/7</div>
              <div class="text-xs text-[#7E7E7E] mt-1">Service</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-[#F48C06]">15+</div>
              <div class="text-xs text-[#7E7E7E] mt-1">Years</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-[#F48C06]">500+</div>
              <div class="text-xs text-[#7E7E7E] mt-1">Projects</div>
            </div>
          </div>

          <!-- Key Benefits -->
          <div class="space-y-2">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#F48C06] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-[#7E7E7E]">Mobile-optimized booking system</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#F48C06] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-[#7E7E7E]">Local SEO optimization</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#F48C06] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-[#7E7E7E]">Customer testimonials & reviews</span>
            </div>
          </div>
        </div>
      </Card>

      <!-- Plumbing Card -->
      <Card
        title="Plumbing Services"
        accent="navy"
        img="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?q=80&w=2070&auto=format&fit=crop"
        imgAlt="Professional plumber working on pipes"
        tags={["🚨 Emergency Repairs", "🔧 Pipe Installation", "🌊 Drain Cleaning", "🔥 Water Heaters"]}
        trade="Plumbing"
        category="Emergency Ready"
        description="Professional plumbers who handle everything from emergency repairs to complete installations. We create websites that capture urgent service calls and showcase your reliability when customers need you most."
      >
        <div class="space-y-4">
          <!-- Stats Section -->
          <div class="grid grid-cols-3 gap-4 py-4 border-t border-b border-gray-200">
            <div class="text-center">
              <div class="text-2xl font-bold text-[#0A1931]">24/7</div>
              <div class="text-xs text-[#7E7E7E] mt-1">Emergency</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-[#0A1931]">12+</div>
              <div class="text-xs text-[#7E7E7E] mt-1">Years</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-[#0A1931]">800+</div>
              <div class="text-xs text-[#7E7E7E] mt-1">Repairs</div>
            </div>
          </div>

          <!-- Key Benefits -->
          <div class="space-y-2">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#0A1931] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-[#7E7E7E]">Emergency call capture system</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#0A1931] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-[#7E7E7E]">Service area mapping</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#0A1931] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-[#7E7E7E]">Before/after project gallery</span>
            </div>
          </div>
        </div>
      </Card>
    </div>
  </div>
</section>

<style>
  /* Smooth transitions */
  * {
    transition-property: transform, box-shadow, background-color, border-color, color;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>