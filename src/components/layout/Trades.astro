---
// Trades We Serve Section
---

<section class="bg-parchment py-20 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-block px-6 py-3 rounded-full text-sm font-semibold tracking-wider uppercase mb-6" style="background: color-mix(in srgb, var(--helios-orange) 15%, transparent); color: var(--helios-orange);">
        Our Expertise
      </div>
      <h2 class="text-4xl md:text-5xl font-bold mb-6" style="color: var(--midnight-navy);">
        Trades We Serve
      </h2>
      <p class="text-lg max-w-4xl mx-auto leading-relaxed text-machinist">
        BuildPro specializes in creating powerful websites for contractors in essential home service industries. For <span class="font-bold" style="color: var(--helios-orange);">8 years</span> we've focused exclusively on HVAC and plumbing contractors, understanding the unique challenges and opportunities in these trades. Our deep industry knowledge combined with proven web design strategies helps contractors dominate their local markets and grow their businesses online.
      </p>
    </div>

    <!-- Trades Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
      <!-- HVAC -->
      <div class="bg-white rounded-2xl overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.08)] transition-all duration-300 border border-black/5 group hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.15)]">
        <div class="relative overflow-hidden">
          <img src="https://images.unsplash.com/photo-1581094794329-c8112a89af12?q=80&w=2070&auto=format&fit=crop" alt="HVAC technician working on air conditioning unit" class="w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105" />
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-95 transition-all duration-300" style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 80%, var(--helios-orange) 20%) 100%);">
            <div class="text-center transform translate-y-5 group-hover:translate-y-0 transition-transform duration-300">
              <svg class="w-12 h-12 text-white mb-4 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <p class="text-white text-sm">Heating, cooling, and ventilation solutions</p>
            </div>
          </div>
        </div>
        <div class="p-8 md:p-6">
          <h3 class="text-2xl md:text-xl font-bold mb-4 font-[Poppins]" style="color: var(--midnight-navy);">HVAC</h3>
          <div class="flex flex-wrap gap-2 sm:justify-center">
            <span class="px-4 py-2 rounded-full text-sm font-semibold font-[Poppins] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.15)]" style="background: color-mix(in srgb, var(--helios-orange) 15%, transparent); color: var(--helios-orange); border: 1px solid color-mix(in srgb, var(--helios-orange) 30%, transparent);">Logo Design</span>
            <span class="px-4 py-2 rounded-full text-sm font-semibold font-[Poppins] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.15)]" style="background: color-mix(in srgb, var(--midnight-navy) 15%, transparent); color: var(--midnight-navy); border: 1px solid color-mix(in srgb, var(--midnight-navy) 30%, transparent);">Web Design</span>
            <span class="px-4 py-2 rounded-full text-sm font-semibold font-[Poppins] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.15)]" style="background: color-mix(in srgb, var(--steel-pewter) 15%, transparent); color: var(--steel-pewter); border: 1px solid color-mix(in srgb, var(--steel-pewter) 30%, transparent);">Marketing</span>
          </div>
        </div>
      </div>

      <!-- Plumbing -->
      <div class="bg-white rounded-2xl overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.08)] transition-all duration-300 border border-black/5 group hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.15)]">
        <div class="relative overflow-hidden">
          <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?q=80&w=2070&auto=format&fit=crop" alt="Plumber working on pipes" class="w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105" />
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-95 transition-all duration-300" style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 80%, var(--helios-orange) 20%) 100%);">
            <div class="text-center transform translate-y-5 group-hover:translate-y-0 transition-transform duration-300">
              <svg class="w-12 h-12 text-white mb-4 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 7.172V5L8 4z"/>
              </svg>
              <p class="text-white text-sm">Complete plumbing services and repairs</p>
            </div>
          </div>
        </div>
        <div class="p-8 md:p-6">
          <h3 class="text-2xl md:text-xl font-bold mb-4 font-[Poppins]" style="color: var(--midnight-navy);">Plumbing</h3>
          <div class="flex flex-wrap gap-2 sm:justify-center">
            <span class="px-4 py-2 rounded-full text-sm font-semibold font-[Poppins] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.15)]" style="background: color-mix(in srgb, var(--helios-orange) 15%, transparent); color: var(--helios-orange); border: 1px solid color-mix(in srgb, var(--helios-orange) 30%, transparent);">Logo Design</span>
            <span class="px-4 py-2 rounded-full text-sm font-semibold font-[Poppins] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.15)]" style="background: color-mix(in srgb, var(--midnight-navy) 15%, transparent); color: var(--midnight-navy); border: 1px solid color-mix(in srgb, var(--midnight-navy) 30%, transparent);">Web Design</span>
            <span class="px-4 py-2 rounded-full text-sm font-semibold font-[Poppins] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.15)]" style="background: color-mix(in srgb, var(--steel-pewter) 15%, transparent); color: var(--steel-pewter); border: 1px solid color-mix(in srgb, var(--steel-pewter) 30%, transparent);">Marketing</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Call to Action -->
    <div class="text-center">
      <button class="inline-flex items-center px-8 py-4 text-white text-lg font-bold rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl" style="background: linear-gradient(135deg, var(--helios-orange) 0%, color-mix(in srgb, var(--helios-orange) 80%, var(--midnight-navy) 20%) 100%);" onmouseover="this.style.transform='scale(1.05) translateY(-2px)'" onmouseout="this.style.transform='scale(1)'">
        <span>View All Trades We Work With</span>
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  /* No custom styles needed - all converted to Tailwind */
</style>