---
// Results Infographic - High-impact metrics showcase
// Displays key performance indicators with icons

const metrics = [
  {
    number: "2,500+",
    label: "Websites Built",
    icon: "globe",
    description: "Professional templates deployed for contractors",
  },
  {
    number: "150%",
    label: "Average Lead Increase",
    icon: "chart",
    description: "Measurable growth in customer inquiries",
  },
  {
    number: "4.9/5",
    label: "Client Satisfaction",
    icon: "star",
    description: "Rating from verified contractor reviews",
  },
];
---

<section class="py-20 md:py-32 px-6 bg-parchment">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16 md:mb-20">
      <span
        class="text-sm font-semibold tracking-widest uppercase text-steel-pewter"
        style="color: var(--helios-orange);"
      >
        THE RESULTS
      </span>
      <h2 class="heading-primary mt-4 mb-4">
        Proven Impact by the Numbers
      </h2>
      <p class="text-lg text-machinist max-w-2xl mx-auto leading-relaxed">
        Real results from real contractors using BuildPro templates
      </p>
    </div>

    <!-- Metrics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {metrics.map((metric) => (
        <div
          class="group relative bg-white rounded-2xl border border-[#E5E7EB] p-8 md:p-10 transition-all duration-300 hover:shadow-lg hover:border-[#F48C06]/30 card-hover"
        >
          <!-- Icon Container -->
          <div class="mb-8">
            <div
              class="w-16 h-16 rounded-xl flex items-center justify-center transition-all duration-300 group-hover:scale-110"
              style="background: linear-gradient(135deg, var(--helios-orange), #ff6b35);"
            >
              {metric.icon === "globe" && (
                <svg
                  class="w-8 h-8 text-white"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20H7m6-4h.01M9 20h6"
                  />
                </svg>
              )}
              {metric.icon === "chart" && (
                <svg
                  class="w-8 h-8 text-white"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 7h8m0 0v8m0-8L5.586 19.414M7 13v8m0 0H3m4 0v-4"
                  />
                </svg>
              )}
              {metric.icon === "star" && (
                <svg
                  class="w-8 h-8 text-white"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              )}
            </div>
          </div>

          <!-- Content -->
          <div class="space-y-4">
            <!-- Number -->
            <div class="text-5xl md:text-6xl font-extrabold text-[#0A1931] leading-none">
              {metric.number}
            </div>

            <!-- Label -->
            <h3 class="text-xl md:text-2xl font-bold text-[#0A1931]">
              {metric.label}
            </h3>

            <!-- Description -->
            <p class="text-machinist leading-relaxed">
              {metric.description}
            </p>
          </div>

          <!-- Decorative accent line -->
          <div
            class="absolute bottom-0 left-0 right-0 h-1 rounded-b-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style="background: linear-gradient(to right, var(--helios-orange), var(--steel-blue));"
          />
        </div>
      ))}
    </div>

    <!-- Bottom CTA Text -->
    <div class="text-center mt-16 md:mt-20">
      <p class="text-lg text-machinist max-w-2xl mx-auto">
        Join thousands of contractors who've transformed their digital presence and grown their businesses with BuildPro.
      </p>
    </div>
  </div>
</section>
