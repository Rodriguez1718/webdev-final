---
// Trade Features Component - Reusable section for trade-specific features
import Badge from "../ui/Badge.astro";

export interface Props {
    trade: "hvac" | "plumbing";
    backLink?: string;
    title: string;
    subtitle?: string;
    benefits: string[];
    solutionsTitle: string;
    solutions: Array<{
        title: string;
        description: string;
    }>;
}

const {
    trade,
    backLink = "/trades-we-serve",
    title,
    subtitle,
    benefits,
    solutionsTitle,
    solutions,
} = Astro.props;

// Set colors based on trade
const accentColor = trade === "hvac" ? "#0A1931" : "#F48C06";
const badgeText = trade === "hvac" ? "HVAC" : "PLUMBING";
---

<section class="py-20 md:py-32 px-4 md:px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
        <!-- Back Link -->
        <div class="mb-12">
            <a
                href={backLink}
                class="inline-flex items-center gap-2 text-[#7E7E7E] hover:text-[#0A1931] transition-all duration-300 text-base group"
            >
                <svg
                    class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to Trades
            </a>
        </div>

        <!-- Section Header -->
        <div class="text-center mb-16">
            <div class="inline-block mb-4">
                <Badge text={badgeText} />
            </div>
            <h2 class="text-4xl md:text-5xl font-bold text-[#0A1931] mb-6">
                {title}
            </h2>
            {
                subtitle && (
                    <p class="text-lg md:text-xl text-[#7E7E7E] max-w-4xl mx-auto">
                        {subtitle}{" "}
                        <span
                            class="font-semibold"
                            style={`color: ${accentColor};`}
                        >
                            Contractor Gorilla
                        </span>
                        .
                    </p>
                )
            }
        </div>

        <!-- Benefits Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
            {
                benefits.map((benefit) => (
                    <div class="flex items-start gap-4 p-6 bg-white rounded-xl border border-[#99B0BB]/20 hover:border-[#99B0BB]/40 transition-all duration-300 hover:shadow-lg">
                        <div
                            class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center"
                            style={`background-color: ${accentColor}15;`}
                        >
                            <svg
                                class="w-6 h-6"
                                style={`color: ${accentColor};`}
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"
                                />
                            </svg>
                        </div>
                        <p class="text-base text-[#0A1931] font-medium leading-relaxed">
                            {benefit}
                        </p>
                    </div>
                ))
            }
        </div>

        <!-- Solutions Section -->
        <div>
            <h3
                class="text-3xl md:text-4xl font-bold text-[#0A1931] mb-12 text-center"
            >
                {solutionsTitle}
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {
                    solutions.map((solution) => (
                        <div class="group p-8 bg-gradient-to-br from-white to-[#F5F5F5] rounded-2xl border border-[#99B0BB]/20 hover:border-[#99B0BB]/40 transition-all duration-300 hover:shadow-xl">
                            <div
                                class="w-14 h-14 rounded-xl flex items-center justify-center mb-6 transition-transform duration-300 group-hover:scale-110"
                                style={`background-color: ${accentColor};`}
                            >
                                <svg
                                    class="w-7 h-7 text-white"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M13 10V3L4 14h7v7l9-11h-7z"
                                    />
                                </svg>
                            </div>
                            <h4 class="text-xl md:text-2xl font-bold text-[#0A1931] mb-3">
                                {solution.title}
                            </h4>
                            <p class="text-base text-[#7E7E7E] leading-relaxed">
                                {solution.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
