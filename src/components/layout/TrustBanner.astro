---
// Trust Banner - Displays trust indicators and company stats
---

<section class="bg-white py-16 px-4 md:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- Trust Indicator 1 -->
            <div class="text-center">
                <div class="mb-4 flex justify-center">
                    <div
                        class="w-16 h-16 rounded-full bg-[#F48C06]/10 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-[#F48C06]"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                            ></path>
                        </svg>
                    </div>
                </div>
                <h3 class="text-2xl md:text-3xl font-bold text-[#0A1931] mb-2">
                    2,500+
                </h3>
                <p class="text-[#7E7E7E] font-primary">Contractors Served</p>
            </div>

            <!-- Trust Indicator 2 -->
            <div class="text-center">
                <div class="mb-4 flex justify-center">
                    <div
                        class="w-16 h-16 rounded-full bg-[#F48C06]/10 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-[#F48C06]"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                            ></path>
                        </svg>
                    </div>
                </div>
                <h3 class="text-2xl md:text-3xl font-bold text-[#0A1931] mb-2">
                    $50M+
                </h3>
                <p class="text-[#7E7E7E] font-primary">Revenue Generated</p>
            </div>

            <!-- Trust Indicator 3 -->
            <div class="text-center">
                <div class="mb-4 flex justify-center">
                    <div
                        class="w-16 h-16 rounded-full bg-[#F48C06]/10 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-[#F48C06]"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                            ></path>
                        </svg>
                    </div>
                </div>
                <h3 class="text-2xl md:text-3xl font-bold text-[#0A1931] mb-2">
                    98%
                </h3>
                <p class="text-[#7E7E7E] font-primary">Satisfaction Rate</p>
            </div>

            <!-- Trust Indicator 4 -->
            <div class="text-center">
                <div class="mb-4 flex justify-center">
                    <div
                        class="w-16 h-16 rounded-full bg-[#F48C06]/10 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-[#F48C06]"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                            ></path>
                        </svg>
                    </div>
                </div>
                <h3 class="text-2xl md:text-3xl font-bold text-[#0A1931] mb-2">
                    24/7
                </h3>
                <p class="text-[#7E7E7E] font-primary">Dedicated Support</p>
            </div>
        </div>
    </div>
</section>
