---
import Button from "../ui/Button.astro";
---

<nav class="bg-[var(--primary-color)] shadow-md sticky top-0 z-50">
  <div class="container-custom">
    <div class="flex items-center justify-between h-20 px-4 lg:px-6">
      <!-- Logo / Home Link -->
      <div class="shrink-0">
        <a
          href="/"
          class="font-primary font-bold text-2xl text-[#0A1931] hover:text-[#F48C06] transition-colors duration-200 flex items-center justify-center"
        >
          <img
            src="../../../public/images/logo.png"
            alt=""
            class="w-15.5 h-15.5 rounded"
          />
        </a>
      </div>

      <!-- Desktop Navigation Links -->
      <div class="hidden lg:flex items-center gap-1 flex-1 justify-center">
        <a
          href="/reviews"
          class="font-primary text-white hover:text-[#F48C06] px-3 py-2 text-sm font-medium transition-colors duration-200 whitespace-nowrap"
        >
          Reviews
        </a>
        <a
          href="/our-work"
          class="font-primary text-white hover:text-[#F48C06] px-3 py-2 text-sm font-medium transition-colors duration-200 whitespace-nowrap"
        >
          Our Work
        </a>
        <div class="relative group">
          <a
            href="/trades-we-serve"
            class="font-primary text-white hover:text-[#F48C06] px-3 py-2 text-sm font-medium transition-colors duration-200 flex items-center whitespace-nowrap"
          >
            Trades We Serve
            <svg
              class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:rotate-180"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
          <!-- Dropdown Menu -->
          <div
            class="absolute left-0 mt-2 w-56 bg-white rounded-lg shadow-lg border border-gray-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
          >
            <div class="py-2">
              <a
                href="/trades-we-serve/plumbing"
                class="flex items-center px-4 py-3 text-[#7E7E7E] hover:text-[#F48C06] hover:bg-gray-50 transition-colors duration-200"
              >
                <svg
                  class="w-5 h-5 mr-3 text-[#F48C06]"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                  ></path>
                  <path d="M8 12h8v2H8z"></path>
                  <path d="M12 8v8"></path>
                </svg>
                <div>
                  <div class="font-medium">Plumbing</div>
                  <div class="text-sm text-gray-500">
                    Pipes, fixtures & repairs
                  </div>
                </div>
              </a>
              <a
                href="/trades-we-serve/hvac"
                class="flex items-center px-4 py-3 text-[#7E7E7E] hover:text-[#F48C06] hover:bg-gray-50 transition-colors duration-200"
              >
                <svg
                  class="w-5 h-5 mr-3 text-[#F48C06]"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                  ></path>
                </svg>
                <div>
                  <div class="font-medium">HVAC</div>
                  <div class="text-sm text-gray-500">
                    Heating, cooling & ventilation
                  </div>
                </div>
              </a>
            </div>
          </div>
        </div>
        <a
          href="/what-we-do"
          class="font-primary text-white hover:text-[#F48C06] px-3 py-2 text-sm font-medium transition-colors duration-200 whitespace-nowrap"
        >
          What We Do
        </a>
        <div class="relative group">
          <a
            href="/about"
            class="font-primary text-white hover:text-[#F48C06] px-3 py-2 text-sm font-medium transition-colors duration-200 flex items-center whitespace-nowrap"
          >
            About
          </a>
        </div>
        <a
          href="/contact"
          class="font-primary text-white hover:text-[#F48C06] px-3 py-2 text-sm font-medium transition-colors duration-200 whitespace-nowrap"
        >
          Contact
        </a>
      </div>

      <!-- CTA Button -->
      <div class="hidden lg:flex ml-auto">
        <Button variant="primary" size="md"> Get a Quote </Button>
      </div>

      <!-- Mobile menu button -->
      <div class="lg:hidden ml-auto">
        <button
          type="button"
          class="burger-btn bg-transparent border-none cursor-pointer p-3 flex flex-col gap-1 items-center rounded-lg transition-colors duration-150 hover:bg-white/10 text-white hover:text-[var(--secondary-color)] focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#F48C06]"
          id="burgerBtn"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Toggle menu"
        >
          <div
            class="line line-top h-0.5 rounded-sm bg-current transition-all duration-300 ease-out w-3.5"
          >
          </div>
          <div
            class="line line-middle h-0.5 rounded-sm bg-current transition-all duration-300 ease-out w-6"
          >
          </div>
          <div
            class="line line-bottom h-0.5 rounded-sm bg-current transition-all duration-300 ease-out w-3.5"
          >
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu with smooth slide animation -->
  <div
    class="mobile-menu overflow-hidden transition-all duration-300 ease-in-out max-h-0 lg:hidden"
    id="mobile-menu"
  >
    <div
      class="px-2 pt-2 pb-3 space-y-1 bg-[#F5F5F5] border-t border-[#99B0BB]"
    >
      <a
        href="/reviews"
        class="font-primary text-[#7E7E7E] hover:text-[#0A1931] hover:bg-white block px-3 py-2 text-base font-medium transition-colors duration-200"
        >Reviews</a
      >
      <a
        href="/our-work"
        class="font-primary text-[#7E7E7E] hover:text-[#0A1931] hover:bg-white block px-3 py-2 text-base font-medium transition-colors duration-200"
        >Our Work</a
      >
      <a
        href="/trades-we-serve"
        class="font-primary text-[#7E7E7E] hover:text-[#0A1931] hover:bg-white block px-3 py-2 text-base font-medium transition-colors duration-200"
        >Trades We Serve</a
      >
      <a
        href="/what-we-do"
        class="font-primary text-[#7E7E7E] hover:text-[#0A1931] hover:bg-white block px-3 py-2 text-base font-medium transition-colors duration-200"
        >What We Do</a
      >
      <a
        href="/about"
        class="font-primary text-[#7E7E7E] hover:text-[#0A1931] hover:bg-white block px-3 py-2 text-base font-medium transition-colors duration-200"
        >About</a
      >
      <a
        href="/contact"
        class="font-primary text-[#7E7E7E] hover:text-[#0A1931] hover:bg-white block px-3 py-2 text-base font-medium transition-colors duration-200"
        >Contact</a
      >
      <div class="px-3 py-2">
        <a
          href="/schedule"
          class="btn-primary font-primary w-full text-center block"
          >Schedule a Call with Us</a
        >
      </div>
    </div>
  </div>
</nav>

<script src="/src/scripts/script.js"></script>
