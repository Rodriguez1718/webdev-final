---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
    <main>
        <section
            class="py-20 px-4 md:px-8 lg:px-12"
            style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 90%, var(--steel-pewter) 10%) 100%);"
        >
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-16">
                    <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
                        What We <span style="color: var(--helios-orange);"
                            >Do</span
                        >
                    </h1>
                    <p class="text-xl text-steel-pewter max-w-3xl mx-auto">
                        Comprehensive digital solutions tailored for contractors
                        and trades professionals
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
                    <!-- Service 1 -->
                    <div
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:bg-white/15 transition-all duration-300"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4">
                            Web Design & Development
                        </h3>
                        <p class="text-steel-pewter leading-relaxed">
                            Custom-built websites designed to convert visitors
                            into customers. Responsive, fast, and optimized for
                            all devices.
                        </p>
                    </div>

                    <!-- Service 2 -->
                    <div
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:bg-white/15 transition-all duration-300"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4">
                            SEO & Local Marketing
                        </h3>
                        <p class="text-steel-pewter leading-relaxed">
                            Get found by customers searching for your services.
                            Local SEO optimization to dominate your market.
                        </p>
                    </div>

                    <!-- Service 3 -->
                    <div
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:bg-white/15 transition-all duration-300"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4">
                            Booking & CRM Systems
                        </h3>
                        <p class="text-steel-pewter leading-relaxed">
                            Integrated booking systems and customer management
                            tools to streamline your operations.
                        </p>
                    </div>

                    <!-- Service 4 -->
                    <div
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:bg-white/15 transition-all duration-300"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4">
                            Ongoing Support
                        </h3>
                        <p class="text-steel-pewter leading-relaxed">
                            Dedicated support team available 24/7 to keep your
                            digital presence running smoothly.
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>
