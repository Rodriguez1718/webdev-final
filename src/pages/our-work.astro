---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/layout/CTASection.astro";
import Hero2 from "../components/layout/Hero2.astro";
import Card from "../components/ui/Card.astro";
---

<BaseLayout>
    <main>
        <Hero2
            eyebrow="OUR PORTFOLIO"
            headline="Explore Our Work"
            highlightWord="Work"
            description="See how we've transformed businesses across the trades industry with innovative digital solutions and proven results."
            showForm={true}
        />
        <section
            class="py-20 px-4 md:px-8 lg:px-12"
            style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 90%, var(--steel-pewter) 10%) 100%);"
        >
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-16"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <Card
                        title="CoolAir Pro"
                        description="Complete website redesign with integrated booking system and local SEO optimization."
                        tags={["Web Design", "SEO"]}
                        accent="orange"
                    >
                        <div class="text-sm font-semibold text-[#F48C06] mb-2">
                            340% Lead Increase
                        </div>
                        <p class="text-xs text-[#7E7E7E]">
                            HVAC Company Website
                        </p>
                    </Card>

                    <Card
                        title="Rapid Plumbing Pro"
                        description="Mobile-optimized website with emergency booking and service area expansion."
                        tags={["Mobile Design", "Booking System"]}
                        accent="orange"
                    >
                        <div class="text-sm font-semibold text-[#F48C06] mb-2">
                            200% Call Volume Increase
                        </div>
                        <p class="text-xs text-[#7E7E7E]">
                            Plumbing Services Website
                        </p>
                    </Card>
                </div>
            </div>
        </section>
        <CTASection />
    </main>
</BaseLayout>
