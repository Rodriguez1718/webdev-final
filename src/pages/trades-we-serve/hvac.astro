---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/layout/CTASection.astro";
import FAQ from "../../components/layout/FAQ.astro";
import Hero2 from "../../components/layout/Hero2.astro";
---

<BaseLayout>
    <main>
        <Hero2
            eyebrow="HVAC SOLUTIONS"
            headline="HVAC Services"
            highlightWord="Services"
            description="Specialized digital solutions designed specifically for HVAC contractors and service providers to grow their business and reach more customers."
            showForm={true}
        />
        <section
            class="py-20 px-4 md:px-8 lg:px-12"
            style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 90%, var(--steel-pewter) 10%) 100%);"
        >
            <div class="max-w-7xl mx-auto">
                <div class="mb-16">
                    <a
                        href="/trades-we-serve"
                        class="text-orange-500 hover:text-orange-400 mb-4 inline-block"
                        >← Back to Trades</a
                    >
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    <div>
                        <h2
                            class="text-4xl md:text-5xl font-bold text-white mb-6"
                        >
                            Why HVAC Companies Need Digital Marketing
                        </h2>
                        <ul class="space-y-4 text-steel-pewter">
                            <li class="flex gap-3">
                                <span style="color: var(--helios-orange);"
                                    >✓</span
                                >
                                <span>Seasonal demand visibility</span>
                            </li>
                            <li class="flex gap-3">
                                <span style="color: var(--helios-orange);"
                                    >✓</span
                                >
                                <span>Maintenance plan promotions</span>
                            </li>
                            <li class="flex gap-3">
                                <span style="color: var(--helios-orange);"
                                    >✓</span
                                >
                                <span>Emergency service availability</span>
                            </li>
                            <li class="flex gap-3">
                                <span style="color: var(--helios-orange);"
                                    >✓</span
                                >
                                <span
                                    >Technician credentials and certifications</span
                                >
                            </li>
                            <li class="flex gap-3">
                                <span style="color: var(--helios-orange);"
                                    >✓</span
                                >
                                <span>Service area expansion opportunities</span
                                >
                            </li>
                        </ul>
                    </div>

                    <div
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8"
                    >
                        <h3 class="text-2xl font-bold text-white mb-6">
                            Our HVAC Solutions
                        </h3>
                        <div class="space-y-4">
                            <div>
                                <p class="text-orange-500 font-semibold mb-2">
                                    Service Showcase Website
                                </p>
                                <p class="text-steel-pewter text-sm">
                                    Highlight heating, cooling, and maintenance
                                    services
                                </p>
                            </div>
                            <div>
                                <p class="text-orange-500 font-semibold mb-2">
                                    Maintenance Plan Management
                                </p>
                                <p class="text-steel-pewter text-sm">
                                    Online portal for customers to manage
                                    service plans
                                </p>
                            </div>
                            <div>
                                <p class="text-orange-500 font-semibold mb-2">
                                    Local SEO for HVAC
                                </p>
                                <p class="text-steel-pewter text-sm">
                                    Rank high for seasonal HVAC searches in your
                                    area
                                </p>
                            </div>
                            <div>
                                <p class="text-orange-500 font-semibold mb-2">
                                    Lead Generation Campaigns
                                </p>
                                <p class="text-steel-pewter text-sm">
                                    Targeted ads for seasonal demand periods
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <FAQ />
        <CTASection />
    </main>
</BaseLayout>
