---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/layout/CTASection.astro";
import FAQ from "../../components/layout/FAQ.astro";
import Hero2 from "../../components/layout/Hero2.astro";
import TradeFeatures from "../../components/layout/TradeFeatures.astro";
import TemplateGallery from "../../components/layout/TemplateGallery.astro";

const hvacBenefits = [
    "Seasonal demand visibility",
    "Maintenance plan promotions",
    "Emergency service availability",
    "Technician credentials and certifications",
    "Service area expansion opportunities",
];

const hvacSolutions = [
    {
        title: "Service Showcase Website",
        description: "Highlight heating, cooling, and maintenance services",
    },
    {
        title: "Maintenance Plan Management",
        description: "Online portal for customers to manage service plans",
    },
    {
        title: "Local SEO for HVAC",
        description: "Rank high for seasonal HVAC searches in your area",
    },
    {
        title: "Lead Generation Campaigns",
        description: "Targeted ads for seasonal demand periods",
    },
];
---

<BaseLayout>
    <main>
        <Hero2
            eyebrow="HVAC SOLUTIONS"
            headline="HVAC Services"
            highlightWord="Services"
            description="Specialized digital solutions designed specifically for HVAC contractors and service providers to grow their business and reach more customers."
            showForm={true}
        />
        <TradeFeatures
            trade="hvac"
            title="What's Included With Our HVAC Website Design Services"
            subtitle="We implement the latest and greatest technology for all the HVAC websites we build. Your website design is in good hands with"
            benefits={hvacBenefits}
            solutionsTitle="Our HVAC Solutions"
            solutions={hvacSolutions}
        />
        <TemplateGallery trade="hvac" />
        <FAQ />
        <CTASection />
    </main>
</BaseLayout>
