---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/layout/CTASection.astro";
import FAQ from "../components/layout/FAQ.astro";
import Hero2 from "../components/layout/Hero2.astro";
---

<BaseLayout>
    <main>
        <Hero2
            eyebrow="INDUSTRY SOLUTIONS"
            headline="Trades We Serve"
            highlightWord="Serve"
            description="Specialized digital solutions tailored for every trade and service industry. From plumbing to HVAC, we've got your business covered."
            showForm={true}
        />
        <section
            class="py-20 px-4 md:px-8 lg:px-12"
            style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 90%, var(--steel-pewter) 10%) 100%);"
        >
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-16"></div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
                >
                    <!-- Plumbing -->
                    <a
                        href="/trades-we-serve/plumbing"
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:border-orange-500 hover:bg-white/15 transition-all duration-300 group"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2">
                            Plumbing
                        </h3>
                        <p class="text-steel-pewter">
                            Pipes, fixtures, repairs, and emergency services
                        </p>
                    </a>

                    <!-- HVAC -->
                    <a
                        href="/trades-we-serve/hvac"
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:border-orange-500 hover:bg-white/15 transition-all duration-300 group"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2">HVAC</h3>
                        <p class="text-steel-pewter">
                            Heating, cooling, ventilation, and maintenance
                        </p>
                    </a>

                    <!-- Electrical -->
                    <a
                        href="/trades-we-serve/electrical"
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:border-orange-500 hover:bg-white/15 transition-all duration-300 group"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2">
                            Electrical
                        </h3>
                        <p class="text-steel-pewter">
                            Wiring, installations, repairs, and inspections
                        </p>
                    </a>

                    <!-- Carpentry -->
                    <a
                        href="/trades-we-serve/carpentry"
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:border-orange-500 hover:bg-white/15 transition-all duration-300 group"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2">
                            Carpentry
                        </h3>
                        <p class="text-steel-pewter">
                            Framing, finishing, custom work, and repairs
                        </p>
                    </a>

                    <!-- Roofing -->
                    <a
                        href="/trades-we-serve/roofing"
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:border-orange-500 hover:bg-white/15 transition-all duration-300 group"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2">
                            Roofing
                        </h3>
                        <p class="text-steel-pewter">
                            Installation, repair, maintenance, and inspection
                        </p>
                    </a>

                    <!-- General Contracting -->
                    <a
                        href="/trades-we-serve/general"
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-8 hover:border-orange-500 hover:bg-white/15 transition-all duration-300 group"
                    >
                        <div
                            class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center"
                            style="background: linear-gradient(135deg, var(--helios-orange) 0%, #ff6b35 100%);"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2">
                            General Contracting
                        </h3>
                        <p class="text-steel-pewter">
                            Project management, renovations, and construction
                        </p>
                    </a>
                </div>
            </div>
        </section>
        <FAQ />
        <CTASection />
    </main>
</BaseLayout>
